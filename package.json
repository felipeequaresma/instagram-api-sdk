{
  "name": "@felipeequaresma/instagram-api-sdk",
  "version": "1.0.2",
  "description": "TypeScript SDK for Instagram Graph API with authentication, messaging, comments, and webhooks",
  "repository": {
    "type": "git",
    "url": "https://github.com/felipeequaresma/instagram-api-sdk.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run type-check && npm run lint && npm test"
  },
  "keywords": [
    "instagram",
    "instagram-api",
    "instagram-graph-api",
    "instagram-sdk",
    "oauth",
    "webhooks",
    "direct-messages",
    "comments",
    "typescript"
  ],
  "author": "Felipe Quaresma",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
