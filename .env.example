# Meta app credentials
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# OAuth
INSTAGRAM_REDIRECT_URI=http://localhost:3000/auth/callback
INSTAGRAM_USER_ID=

# Webhooks
WEBHOOK_VERIFY_TOKEN=
PORT=3000

# Local development
DEBUG=true
# Dev only: if the long-lived token exchange fails, keep the short-lived token
# (~1h) instead of aborting OAuth. The real expiry is still controlled by Meta.
ALLOW_SHORT_LIVED_TOKEN=true
